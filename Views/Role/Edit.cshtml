@model School_Management_System.Core.Models.Role
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Edit Role";
    ViewBag.ActiveMenu = "Roles";
}

<div class="space-y-6">
    <!-- Create Form -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <form asp-action="Edit" asp-controller="Role" method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            
            <div class="p-6 space-y-6">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                    <div>
                        <div class="flex items-center gap-3">
                            <div>
                                <h2 class="text-2xl font-bold text-gray-800">Edit Role</h2>
                                <p class="text-gray-500 mt-1">Update the role information below.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Validation Summary -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                        <div class="flex items-center gap-2 text-red-700 mb-2">
                            <i class="fas fa-exclamation-circle"></i>
                            <span class="font-medium">Please correct the following errors:</span>
                        </div>
                        <div asp-validation-summary="All" class="text-sm text-red-600 space-y-1"></div>
                    </div>
                }

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <!-- Left Column -->
                    <div class="space-y-6">
                        <!-- Role Name Field -->
                        <div>
                            <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-2">
                                Name <span class="text-red-500">*</span>
                            </label>
                            <input asp-for="Name" 
                                   class="block w-full shadow-sm sm:text-sm border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500" 
                                   placeholder="Enter role name" />
                            <span asp-validation-for="Name" class="text-sm text-red-600 mt-1 block"></span>
                            <p class="text-xs text-gray-500 mt-1">Role name must be unique and can contain letters, numbers, (3-50 characters).</p>
                        </div>
                    </div>

                    <!-- Right Column - Permissions -->
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                Permissions
                            </label>
                            <div class="border border-gray-300 rounded-md p-4 space-y-2 max-h-96 overflow-y-auto">
                                @if (ViewBag.Permissions != null)
                                {
                                    var permissions = ViewBag.Permissions as IEnumerable<School_Management_System.Models.Permission>;
                                    
                                    @foreach (var permission in permissions)
                                    {
                                        var isChecked = Model.RolesPermissions != null && Model.RolesPermissions
                                                                    .Any(rp => rp.PermissionId == permission.Id);
                                        <label class="flex items-center gap-2">
                                            <input type="checkbox" 
                                                   name="PermissionIds" 
                                                   @(isChecked ? "checked" : "")
                                                   value="@permission.Id" 
                                                   class="rounded border-gray-300" />
                                            <span class="text-sm text-gray-700">@permission.Name</span>
                                        </label>
                                    }
                                }
                                else
                                {
                                    <p class="text-sm text-gray-500">No permissions available</p>
                                }
                            </div>
                            <p class="text-xs text-gray-500 mt-1">Select the permissions you want to assign to this role.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-3">
                <a href="@Url.Action("Index", "Role")" 
                   class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors duration-200">
                    Cancel
                </a>
                <button type="submit" 
                        class="px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-colors duration-200 flex items-center gap-2 shadow-sm">
                    <i class="fas fa-save"></i>
                    <span>Update Role</span>
                </button>
            </div>
        </form>
    </div>
</div>