@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Delete Role";
}
@model School_Management_System.Models.Role;

<h1 class="text-2xl font-bold mb-4">Delete Role</h1>
<div class="bg-white p-6 rounded shadow">
    <h2 class="text-xl font-semibold mb-4">Are you sure you want to delete this role?</h2>
    <div class="mb-4">
        <p><strong>Name:</strong> @Model.Name</p>
    </div>
    <form asp-action="Delete" asp-controller="Role" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600">Delete</button>
        <a asp-action="Index" asp-controller="Role" class="ml-4 bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600">Cancel</a>
    </form>
</div>