@model School_Management_System.Core.Models.Permission

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Create Permission";
    ViewBag.ActiveMenu = "Permissions";
}

<div class="space-y-6">
    <!-- Create Form -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <form asp-action="Create" asp-controller="Permission" method="post" class="space-y-6">
            @Html.AntiForgeryToken()

            <div class="p-6 space-y-6">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                    <div>
                        <div class="flex items-center gap-3">
                            <div>
                                <h2 class="text-2xl font-bold text-gray-800">Create New Permission</h2>
                                <p class="text-gray-500 mt-1">
                                    Add a new permission to the system. Fill in the required information below.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <!-- Left Column -->
                    <div class="space-y-6">
                        <!-- Permission Name Field -->
                        <div>
                            <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-2">
                                Name <span class="text-red-500">*</span>
                            </label>

                            <input asp-for="Name"
                                   class="block w-full px-3 py-2 shadow-sm sm:text-sm border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500"
                                   placeholder="Enter permission name" />

                            <span asp-validation-for="Name" class="text-sm text-red-600 mt-1 block"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-3">
                <a href="@Url.Action("Index", "Permission")"
                   class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors duration-200">
                    Cancel
                </a>

                <button type="submit"
                        class="px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-colors duration-200 flex items-center gap-2 shadow-sm">
                    <i class="fas fa-save"></i>
                    <span>Create Permission</span>
                </button>
            </div>
        </form>
    </div>
</div>
