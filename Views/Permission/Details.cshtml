@model School_Management_System.Core.Models.Permission

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Permission Details";
    ViewBag.ActiveMenu = "Permissions";
}

<div class="space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
            <div class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-3 py-1 text-sm font-medium text-blue-700">
                <i class="fas fa-key"></i>
                <span>Permission Overview</span>
            </div>
            <h1 class="mt-3 text-3xl font-bold text-gray-900">@Model.Name</h1>
            <p class="mt-2 max-w-2xl text-sm text-gray-500">
                View permission identity, audit metadata, and where this permission is currently used.
            </p>
        </div>

        <div class="flex flex-wrap gap-3">
            <a href="@Url.Action("Edit", "Permission", new { id = Model.Id })" class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-indigo-700">
                <i class="fas fa-pen-to-square"></i>
                <span>Edit Permission</span>
            </a>
            <a href="@Url.Action("Index", "Permission")" class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50">
                <i class="fas fa-arrow-left"></i>
                <span>Back to Permissions</span>
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm">
            <p class="text-sm text-gray-500">Permission ID</p>
            <p class="mt-2 text-2xl font-bold text-gray-900">#@Model.Id</p>
        </div>

        <div class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm">
            <p class="text-sm text-gray-500">Used By Roles</p>
            <p class="mt-2 text-2xl font-bold text-indigo-600">@(Model.RolesPermissions?.Count ?? 0)</p>
        </div>

        <div class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm">
            <p class="text-sm text-gray-500">Created</p>
            <p class="mt-2 text-lg font-semibold text-gray-900">@Model.CreatedAt.ToString("MMM dd, yyyy")</p>
            <p class="text-sm text-gray-500">@Model.CreatedAt.ToString("hh:mm tt")</p>
        </div>

        <div class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm">
            <p class="text-sm text-gray-500">Updated</p>
            <p class="mt-2 text-lg font-semibold text-gray-900">@Model.UpdatedAt.ToString("MMM dd, yyyy")</p>
            <p class="text-sm text-gray-500">@Model.UpdatedAt.ToString("hh:mm tt")</p>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <div class="rounded-2xl border border-gray-100 bg-white shadow-sm lg:col-span-1">
            <div class="border-b border-gray-100 px-6 py-5">
                <h2 class="text-lg font-semibold text-gray-900">Permission Profile</h2>
                <p class="mt-1 text-sm text-gray-500">Core information and key metadata.</p>
            </div>

            <div class="space-y-5 px-6 py-6">
                <div class="flex items-center gap-4">
                    <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-sky-500 to-indigo-600 text-2xl font-bold text-white shadow-sm">
                        @(string.IsNullOrWhiteSpace(Model.Name) ? "?" : Model.Name.Trim()[0].ToString().ToUpper())
                    </div>
                    <div>
                        <p class="text-sm text-gray-500">Permission Name</p>
                        <p class="text-xl font-semibold text-gray-900">@Model.Name</p>
                    </div>
                </div>

                <div class="rounded-xl bg-gray-50 p-4">
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Quick facts</p>
                    <div class="mt-3 space-y-3 text-sm">
                        <div class="flex items-center justify-between gap-4">
                            <span class="text-gray-500">Identifier</span>
                            <span class="font-medium text-gray-900">#@Model.Id</span>
                        </div>
                        <div class="flex items-center justify-between gap-4">
                            <span class="text-gray-500">Assigned roles</span>
                            <span class="font-medium text-gray-900">@(Model.RolesPermissions?.Count ?? 0)</span>
                        </div>
                        <div class="flex items-center justify-between gap-4">
                            <span class="text-gray-500">Last updated</span>
                            <span class="font-medium text-gray-900">@Model.UpdatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="rounded-2xl border border-gray-100 bg-white shadow-sm lg:col-span-2">
            <div class="border-b border-gray-100 px-6 py-5">
                <h2 class="text-lg font-semibold text-gray-900">Roles With This Permission</h2>
                <p class="mt-1 text-sm text-gray-500">Roles that currently include this permission.</p>
            </div>

            <div class="px-6 py-6">
                @if (Model.RolesPermissions != null && Model.RolesPermissions.Any())
                {
                    <div class="flex flex-wrap gap-3">
                        @foreach (var rolePermission in Model.RolesPermissions)
                        {
                            if (rolePermission.Role != null)
                            {
                                <a href="@Url.Action("Details", "Role", new { id = rolePermission.RoleId })" class="inline-flex items-center gap-2 rounded-full border border-blue-100 bg-blue-50 px-4 py-2 text-sm font-medium text-blue-700 transition-colors hover:bg-blue-100">
                                    <i class="fas fa-user-tag text-xs"></i>
                                    <span>@rolePermission.Role.Name</span>
                                </a>
                            }
                        }
                    </div>
                }
                else
                {
                    <div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-gray-200 bg-gray-50 px-6 py-12 text-center">
                        <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white text-gray-400 shadow-sm">
                            <i class="fas fa-users-slash text-xl"></i>
                        </div>
                        <h3 class="mt-4 text-lg font-semibold text-gray-900">No roles assigned</h3>
                        <p class="mt-2 max-w-md text-sm text-gray-500">
                            This permission is not currently assigned to any role in the system.
                        </p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>