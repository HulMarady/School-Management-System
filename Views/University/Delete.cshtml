@model School_Management_System.Models.University
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Delete University";
    ViewBag.ActiveMenu = "Universities";
}

<div class="min-h-[calc(100vh-9rem)] flex items-center justify-center">
    <div class="relative w-full max-w-lg overflow-hidden rounded-2xl bg-white shadow-2xl border border-gray-100" role="dialog" aria-modal="true" aria-labelledby="delete-university-title" aria-describedby="delete-university-description">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-red-500 via-rose-500 to-orange-500"></div>

        <div class="p-6 sm:p-8">
            <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-100 text-red-600 flex-shrink-0">
                    <i class="fas fa-triangle-exclamation text-xl"></i>
                </div>

                <div class="flex-1">
                    <h1 id="delete-university-title" class="text-2xl font-bold text-gray-900">Delete University</h1>
                    <p id="delete-university-description" class="mt-2 text-sm text-gray-600">
                        This action cannot be undone. Deleting this university will permanently remove it from the system.
                    </p>
                </div>
            </div>

            <div class="mt-6 rounded-xl bg-gray-50 border border-gray-200 p-4 space-y-3">
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">University details</p>
                <div class="flex items-center justify-between gap-3">
                    <span class="text-sm text-gray-600">Name</span>
                    <span class="text-base font-semibold text-gray-900">@Model.Name</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                    <span class="text-sm text-gray-600">Email</span>
                    <span class="text-sm font-medium text-gray-900 break-all text-right">@Model.Email</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                    <span class="text-sm text-gray-600">Location</span>
                    <span class="text-sm font-medium text-gray-900 text-right">@(string.IsNullOrWhiteSpace(Model.Location) ? "N/A" : Model.Location)</span>
                </div>
            </div>

            <form asp-action="Delete" asp-controller="University" method="post" class="mt-6 flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" asp-controller="University" class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors duration-200">
                    Cancel
                </a>
                <button type="submit" class="inline-flex items-center justify-center gap-2 rounded-lg bg-red-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors duration-200">
                    <i class="fas fa-trash-alt"></i>
                    <span>Delete University</span>
                </button>
            </form>
        </div>
    </div>
</div>
