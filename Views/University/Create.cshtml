@model School_Management_System.Models.University
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Create University";
    ViewBag.ActiveMenu = "Universities";
}

<div class="container mx-auto px-0">
    <!-- Create Form -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <form asp-action="Create" asp-controller="University" method="post">
            @Html.AntiForgeryToken()

            <div class="p-6">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
                    <div>
                        <div class="flex items-center gap-3">
                            <div>
                                <h2 class="text-2xl font-bold text-gray-800">Create New University</h2>
                                <p class="text-gray-500 mt-1">
                                    Add a new university to the system. Fill in the required information below.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex flex-wrap -mx-3">
                    <div class="w-full lg:w-1/2 md:w-2/3 px-3">
                        <!-- University Name Field -->
                        <div class="mb-6">
                            <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-2">
                                Name <span class="text-red-500">*</span>
                            </label>

                            <input asp-for="Name"
                                   class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500"
                                   placeholder="Enter university name" />

                            <span asp-validation-for="Name" class="text-sm text-red-600 mt-1 block"></span>
                        </div>

                        <!-- Email Field -->
                        <div class="mb-6">
                            <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-2">
                                Email <span class="text-red-500">*</span>
                            </label>

                            <input asp-for="Email"
                                   type="email"
                                   class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500"
                                   placeholder="Enter university email" />

                            <span asp-validation-for="Email" class="text-sm text-red-600 mt-1 block"></span>
                        </div>

                        <!-- Location Field -->
                        <div class="mb-6">
                            <label asp-for="Location" class="block text-sm font-medium text-gray-700 mb-2">
                                Location
                            </label>

                            <input asp-for="Location"
                                   class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500"
                                   placeholder="Enter university location" />

                            <span asp-validation-for="Location" class="text-sm text-red-600 mt-1 block"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-3">
                <a href="@Url.Action("Index", "University")"
                   class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors duration-200">
                    Cancel
                </a>

                <button type="submit"
                        class="px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-colors duration-200 flex items-center gap-2 shadow-sm">
                    <i class="fas fa-save"></i>
                    <span>Create University</span>
                </button>
            </div>
        </form>
    </div>
</div>