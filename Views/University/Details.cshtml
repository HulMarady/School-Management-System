@model School_Management_System.Models.University
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "University Details";
    ViewBag.ActiveMenu = "Universities";
}

<div class="space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
            <div class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-3 py-1 text-sm font-medium text-indigo-700">
                <i class="fas fa-university"></i>
                <span>University Overview</span>
            </div>
            <h1 class="mt-3 text-3xl font-bold text-gray-900">@Model.Name</h1>
            <p class="mt-2 max-w-2xl text-sm text-gray-500">
                Review university profile details, contact information, and audit timestamps.
            </p>
        </div>

        <div class="flex flex-wrap gap-3">
            <a href="@Url.Action("Edit", "University", new { id = Model.Id })" class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-indigo-700">
                <i class="fas fa-pen-to-square"></i>
                <span>Edit University</span>
            </a>
            <a href="@Url.Action("Delete", "University", new { id = Model.Id })" class="inline-flex items-center gap-2 rounded-lg bg-red-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-red-700">
                <i class="fas fa-trash-alt"></i>
                <span>Delete</span>
            </a>
            <a href="@Url.Action("Index", "University")" class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50">
                <i class="fas fa-arrow-left"></i>
                <span>Back to Universities</span>
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm">
            <p class="text-sm text-gray-500">University ID</p>
            <p class="mt-2 text-2xl font-bold text-gray-900">#@Model.Id</p>
        </div>

        <div class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm">
            <p class="text-sm text-gray-500">Status</p>
            <p class="mt-2 inline-flex items-center gap-2 rounded-full bg-green-100 px-3 py-1 text-sm font-semibold text-green-700">
                <i class="fas fa-circle-check text-xs"></i>
                <span>Active</span>
            </p>
        </div>

        <div class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm">
            <p class="text-sm text-gray-500">Created</p>
            <p class="mt-2 text-lg font-semibold text-gray-900">@Model.CreatedAt.ToString("MMM dd, yyyy")</p>
            <p class="text-sm text-gray-500">@Model.CreatedAt.ToString("hh:mm tt")</p>
        </div>

        <div class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm">
            <p class="text-sm text-gray-500">Updated</p>
            <p class="mt-2 text-lg font-semibold text-gray-900">@Model.UpdatedAt.ToString("MMM dd, yyyy")</p>
            <p class="text-sm text-gray-500">@Model.UpdatedAt.ToString("hh:mm tt")</p>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <div class="rounded-2xl border border-gray-100 bg-white shadow-sm lg:col-span-1">
            <div class="border-b border-gray-100 px-6 py-5">
                <h2 class="text-lg font-semibold text-gray-900">University Profile</h2>
                <p class="mt-1 text-sm text-gray-500">Primary university information.</p>
            </div>

            <div class="space-y-5 px-6 py-6">
                <div class="flex items-center gap-4">
                    <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-500 to-blue-600 text-2xl font-bold text-white shadow-sm">
                        @(string.IsNullOrWhiteSpace(Model.Name) ? "?" : Model.Name.Trim()[0].ToString().ToUpper())
                    </div>
                    <div>
                        <p class="text-sm text-gray-500">Display Name</p>
                        <p class="text-xl font-semibold text-gray-900">@Model.Name</p>
                    </div>
                </div>

                <div class="rounded-xl bg-gray-50 p-4">
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Quick facts</p>
                    <div class="mt-3 space-y-3 text-sm">
                        <div class="flex items-center justify-between gap-4">
                            <span class="text-gray-500">Identifier</span>
                            <span class="font-medium text-gray-900">#@Model.Id</span>
                        </div>
                        <div class="flex items-center justify-between gap-4">
                            <span class="text-gray-500">Email available</span>
                            <span class="font-medium text-gray-900">@(string.IsNullOrWhiteSpace(Model.Email) ? "No" : "Yes")</span>
                        </div>
                        <div class="flex items-center justify-between gap-4">
                            <span class="text-gray-500">Location set</span>
                            <span class="font-medium text-gray-900">@(string.IsNullOrWhiteSpace(Model.Location) ? "No" : "Yes")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="rounded-2xl border border-gray-100 bg-white shadow-sm lg:col-span-2">
            <div class="border-b border-gray-100 px-6 py-5">
                <h2 class="text-lg font-semibold text-gray-900">Contact & Location</h2>
                <p class="mt-1 text-sm text-gray-500">Registered contact details and address information.</p>
            </div>

            <div class="space-y-4 px-6 py-6">
                <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Email Address</p>
                    <p class="mt-2 text-base font-medium text-gray-900 break-all">@Model.Email</p>
                </div>

                <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Location</p>
                    @if (!string.IsNullOrWhiteSpace(Model.Location))
                    {
                        <p class="mt-2 text-base font-medium text-gray-900">@Model.Location</p>
                    }
                    else
                    {
                        <p class="mt-2 text-sm text-gray-500 italic">No location has been provided.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
