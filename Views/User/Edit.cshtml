@using School_Management_System.Models
@model School_Management_System.Models.User
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "Edit User";
    ViewBag.ActiveMenu = "Users";
}

<div class="space-y-6">


    <!-- Edit Form Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">

        <!-- Page Header -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 p-6">
            <div>
                <div class="flex items-center gap-3">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-800">Edit User</h2>
                        <p class="text-gray-500 mt-1">Update profile information for this account.</p>
                    </div>
                </div>
            </div>
            @* <div class="flex items-center gap-3">
                <a href="@Url.Action("Details", "User", new { id = Model.Id })" 
                class="border border-gray-300 bg-white hover:bg-gray-50 text-gray-700 px-4 py-2 rounded-lg transition-colors duration-200 flex items-center gap-2">
                    <i class="fas fa-eye"></i>
                    <span>View</span>
                </a>
                <button type="submit" form="editUserForm" 
                        class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg transition-colors duration-200 flex items-center gap-2 shadow-sm">
                    <i class="fas fa-save"></i>
                    <span>Save Changes</span>
                </button>
            </div> *@
        </div>
        <form id="editUserForm" asp-action="Edit" asp-controller="User" method="post" class="space-y-2">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="Password" type="hidden" />

            <div class="p-6 space-y-6">
                <!-- Validation Summary -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                        <div class="flex items-center gap-2 text-red-700 mb-2">
                            <i class="fas fa-exclamation-circle"></i>
                            <span class="font-medium">Please correct the following errors:</span>
                        </div>
                        <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 space-y-1"></div>
                    </div>
                }

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <!-- Left Column -->
                    <div class="space-y-6">
                        <!-- Username Field -->
                        <div>
                            <label asp-for="Username" class="block text-sm font-medium text-gray-700 mb-2">
                                Username <span class="text-red-500">*</span>
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <i class="fas fa-user text-gray-400"></i>
                                </div>
                                <input asp-for="Username" 
                                       type="text" 
                                       class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all @(ViewData.ModelState.ContainsKey("Username") && ViewData.ModelState["Username"].Errors.Any() ? "border-red-500" : "")"
                                       placeholder="Enter username" />
                            </div>
                            <span asp-validation-for="Username" class="text-sm text-red-600 mt-1 block"></span>
                            <p class="text-xs text-gray-500 mt-1">Username must be unique and can contain letters, numbers, and underscores (3-50 characters).</p>
                        </div>

                        <!-- Email Field -->
                        <div>
                            <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-2">
                                Email Address <span class="text-red-500">*</span>
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <i class="fas fa-envelope text-gray-400"></i>
                                </div>
                                <input asp-for="Email" 
                                       type="email" 
                                       class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all @(ViewData.ModelState.ContainsKey("Email") && ViewData.ModelState["Email"].Errors.Any() ? "border-red-500" : "")"
                                       placeholder="user@example.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-sm text-red-600 mt-1 block"></span>
                            <p class="text-xs text-gray-500 mt-1">A valid email address is required for notifications and password recovery.</p>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="space-y-6">
                        <!-- Role Field -->
                        <div>
                            <label name="RoleId" class="block text-sm font-medium text-gray-700 mb-2">
                                Role <span class="text-red-500">*</span>
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <i class="fas fa-tag text-gray-400"></i>
                                </div>
                                <select name="RoleId" 
                                        class="block w-full pl-10 pr-10 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all appearance-none bg-white">
                                    <option value="">Select a role</option>
                                    @foreach(var role in ViewBag.Roles as IEnumerable<Role>)
                                    {
                                        var isSelected = Model.UserRoles != null && Model.UserRoles.Any(ur => ur.RoleId == role.Id);
                                        <option value="@role.Id" selected=@(isSelected ? "selected" : "")>@role.Name</option>
                                    }
                                </select>
                                <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                                    <i class="fas fa-chevron-down text-gray-400"></i>
                                </div>
                            </div>
                            @* <span asp-validation-for="RoleId" class="text-sm text-red-600 mt-1 block"></span> *@
                        </div> 

                        <!-- Password Change Section -->
                        @* <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                            <div class="flex items-start gap-3">
                                <i class="fas fa-key text-blue-600 mt-0.5"></i>
                                <div class="flex-1">
                                    <p class="text-sm font-medium text-blue-800 mb-2">Password Management</p>
                                    <p class="text-xs text-blue-600 mb-3">To change the password, please use the password reset functionality.</p>
                                    <a href="@Url.Action("ResetPassword", "User", new { id = Model.Id })" 
                                       class="inline-flex items-center gap-2 text-sm text-blue-700 hover:text-blue-800 font-medium">
                                        <i class="fas fa-redo-alt"></i>
                                        <span>Reset Password</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                        *@
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-3">
                <a href="@Url.Action("Index", "User")" 
                   class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors duration-200">
                    Cancel
                </a>
                <button type="submit" 
                        class="px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-colors duration-200 flex items-center gap-2 shadow-sm">
                    <i class="fas fa-save"></i>
                    <span>Save Changes</span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}