@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = "User Details";
    ViewBag.ActiveMenu = "Users";
}

@model School_Management_System.Models.User

<div class="w-full">
    <!-- Main Card -->
    <div class="bg-white rounded-xl  border border-gray-200 overflow-hidden">
        <!-- Header -->
        <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border-b border-gray-200 px-6 py-5">
            <div class="flex flex-wrap items-center justify-between gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-gray-800">User Details</h2>
                    <p class="text-sm text-gray-500 mt-1">View and manage user information</p>
                </div>
                <div>
                    @if (!string.IsNullOrEmpty(Model.Role))
                    {
                        string roleBadgeClass = Model.Role.ToLower() switch
                        {
                            "admin" => "bg-red-100 text-red-700",
                            "teacher" => "bg-blue-100 text-blue-700",
                            "student" => "bg-green-100 text-green-700",
                            _ => "bg-gray-100 text-gray-700"
                        };
                        <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium @roleBadgeClass">
                            <i class="fas fa-tag mr-1"></i> @Model.Role
                        </span>
                    }
                </div>
            </div>
        </div>

        <!-- User Profile Summary -->
        <div class="border-b border-gray-200 px-6 py-5">
            <div class="flex items-center space-x-4">
                <div class="w-20 h-20 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center shadow-md">
                    <span class="text-3xl font-bold text-white">
                        @(Model.Username?.FirstOrDefault().ToString().ToUpper() ?? "U")
                    </span>
                </div>
                <div>
                    <h3 class="text-xl font-bold text-gray-800">@Model.Username</h3>
                    <p class="text-gray-500 flex items-center mt-1">
                        <i class="fas fa-envelope text-sm mr-2"></i> @Model.Email
                    </p>
                    <p class="text-sm text-gray-400 mt-1">
                        <i class="fas fa-id-card mr-2"></i> User ID: #@Model.Id
                    </p>
                </div>
            </div>
        </div>

        <!-- Information Grid - 3 Rows, 2 Columns -->
        <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Row 1, Col 1: Username -->
                <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 hover:border-blue-300 transition-colors">
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                        <i class="fas fa-user mr-1"></i> Username
                    </label>
                    <p class="text-gray-800 font-medium text-lg">@Model.Username</p>
                </div>

                <!-- Row 1, Col 2: Email -->
                <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 hover:border-blue-300 transition-colors">
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                        <i class="fas fa-envelope mr-1"></i> Email Address
                    </label>
                    <p class="text-gray-800 font-medium break-all">@Model.Email</p>
                </div>

                <!-- Row 2, Col 1: Role -->
                <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 hover:border-blue-300 transition-colors">
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                        <i class="fas fa-tag mr-1"></i> Role
                    </label>
                    @if (!string.IsNullOrEmpty(Model.Role))
                    {
                        <p class="text-gray-800 font-medium text-lg">@Model.Role</p>
                    }
                    else
                    {
                        <p class="text-gray-400 italic">No role assigned</p>
                    }
                </div>

                <!-- Row 2, Col 2: Member Since -->
                <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 hover:border-blue-300 transition-colors">
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                        <i class="fas fa-calendar-plus mr-1"></i> Member Since
                    </label>
                    <p class="text-gray-800 font-medium text-lg">@Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                </div>

                <!-- Row 3, Col 1: Last Updated -->
                <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 hover:border-blue-300 transition-colors">
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                        <i class="fas fa-sync-alt mr-1"></i> Last Updated
                    </label>
                    <p class="text-gray-800 font-medium text-lg">@Model.UpdatedAt.ToString("MMMM dd, yyyy")</p>
                </div>

                <!-- Row 3, Col 2: Account Age -->
                <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 hover:border-blue-300 transition-colors">
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                        <i class="fas fa-clock mr-1"></i> Account Age
                    </label>
                    <p class="text-gray-800 font-medium text-lg">
                        @{
                            var days = (DateTime.Now - Model.CreatedAt).Days;
                            var months = days / 30;
                            var years = days / 365;
                            
                            if (years > 0)
                            {
                                <text>@years year(s)</text>
                            }
                            else if (months > 0)
                            {
                                <text>@months month(s)</text>
                            }
                            else
                            {
                                <text>@days day(s)</text>
                            }
                        }
                    </p>
                </div>
            </div>

            <!-- Additional Info Card -->
            @* <div class="mt-6 bg-blue-50 rounded-lg p-4 border border-blue-200">
                <div class="flex items-start space-x-3">
                    <i class="fas fa-info-circle text-blue-500 mt-0.5"></i>
                    <div>
                        <p class="text-sm text-blue-800">
                            <span class="font-semibold">Quick Info:</span> This user account was created 
                            @{
                                var daysAgo = (DateTime.Now - Model.CreatedAt).Days;
                                if (daysAgo == 0)
                                {
                                    <text>today</text>
                                }
                                else if (daysAgo == 1)
                                {
                                    <text>yesterday</text>
                                }
                                else
                                {
                                    <text>@daysAgo days ago</text>
                                }
                            }
                        </p>
                    </div>
                </div>
            </div> *@
        </div>

        <!-- Action Buttons -->
        <div class="border-t border-gray-200 px-6 py-4 bg-gray-50">
            <div class="flex flex-wrap gap-3 justify-end">
                <a href="@Url.Action("Index", "User")" 
                   class="inline-flex items-center px-5 py-2.5 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium rounded-lg transition duration-150 shadow-sm">
                    <i class="fas fa-arrow-left mr-2"></i> Back to List
                </a>
                <a href="@Url.Action("Edit", "User", new { id = Model.Id })" 
                   class="inline-flex items-center px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition duration-150 shadow-md">
                    <i class="fas fa-edit mr-2"></i> Edit User
                </a>
                <button onclick="confirmDelete(@Model.Id)" 
                        class="inline-flex items-center px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-lg transition duration-150 shadow-md">
                    <i class="fas fa-trash-alt mr-2"></i> Delete User
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function confirmDelete(userId) {
        if (confirm('Are you sure you want to delete this user? This action cannot be undone.')) {
            window.location.href = '@Url.Action("Delete", "User")/' + userId;
        }
    }
</script>

<style>
    /* Custom Tailwind CSS utilities */
    .transition-colors {
        transition-property: background-color, border-color, color, fill, stroke;
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
        transition-duration: 150ms;
    }
    
    .hover\:border-blue-300:hover {
        border-color: #93c5fd;
    }
    
    button:active {
        transform: scale(0.98);
    }
</style>